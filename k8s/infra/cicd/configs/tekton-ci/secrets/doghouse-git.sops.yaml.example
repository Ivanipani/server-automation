---
# WRITE-capable SSH deploy key for github.com/Ivanipani/doghouse. Used to clone
# the repo and to push the pin commit back to main (the flux doghouse-apps key is
# read-only, so CI needs its own). Generate a dedicated key, add the PUBLIC half
# as a doghouse deploy key with "Allow write access" checked:
#   ssh-keygen -t ed25519 -N '' -C tekton-ci -f doghouse-ci
# Then paste the PRIVATE half below, copy to doghouse-git.sops.yaml, encrypt
# in place with sops, and add it to the kustomization. See README.md.
apiVersion: v1
kind: Secret
metadata:
  name: doghouse-git
  namespace: tekton-ci
type: Opaque
stringData:
  id_ed25519: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    REPLACE_WITH_WRITE_CAPABLE_DEPLOY_KEY
    -----END OPENSSH PRIVATE KEY-----
