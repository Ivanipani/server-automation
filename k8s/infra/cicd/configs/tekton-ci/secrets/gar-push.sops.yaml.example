---
# GAR push (Artifact Registry Writer) credentials, mounted by build-image as a
# docker config.json. Copy to gar-push.sops.yaml, fill config.json, encrypt
# in place with sops, then add it to the kustomization. See README.md.
#
# Build config.json from the writer service-account key (the same _json_key
# login images/justfile uses), e.g.:
#   AUTH=$(printf '_json_key:%s' "$(cat gar-secret.json)" | base64 -w0)
#   jq -n --arg a "$AUTH" \
#     '{auths:{"us-east4-docker.pkg.dev":{auth:$a}}}'
apiVersion: v1
kind: Secret
metadata:
  name: gar-push
  namespace: tekton-ci
type: Opaque
stringData:
  config.json: |
    {"auths":{"us-east4-docker.pkg.dev":{"auth":"REPLACE_WITH_BASE64_json_key_AUTH"}}}
