set dotenv-load := true

pwd := absolute_path(".")

# Default target
default:
    @just --list --unsorted

# SOPS age key for the `infrastructure` Kustomization's decryption block.
# Kept out of git (.gitignore); the public half is the recipient in .sops.yaml.
# flux bootstrap creates the flux-system namespace, so this runs after it.
# Idempotent: re-running bootstrap re-applies rather than erroring.
install-age-secret:
    #!/usr/bin/env bash
    set -euo pipefail
    [[ -f "{{pwd}}/age.agekey" ]] || { echo "age.agekey not found — cannot create sops-age secret" >&2; exit 1; }
    kubectl create secret generic sops-age \
        --namespace=flux-system \
        --from-file=age.agekey="{{pwd}}/age.agekey" \
        --dry-run=client -o yaml | kubectl apply -f -

# Bootstrap Flux on the 'doghouse' cluster
bootstrap-flux:
    flux bootstrap git \
        --url=ssh://git@github.com/Ivanipani/doghouse \
        --branch=main \
        --private-key-file=$HOME/.ssh/github \
        --path=clusters/doghouse
    just install-age-secret

# Fuzzy-pick a *.sops.yaml secret and open it decrypted in $EDITOR (re-encrypts on save).
edit-secret:
    #!/usr/bin/env bash
    set -euo pipefail
    file=$(find . \( -name .git -o -name .jj \) -prune -o \
        -name '*.sops.yaml' ! -name '.sops.yaml' -type f -print \
        | sed 's|^\./||' | sort \
        | fzf --prompt='sops> ' --height=40% --reverse --no-multi) || exit 0
    [[ -n "${file:-}" ]] || { echo "No file selected." >&2; exit 0; }
    SOPS_AGE_KEY_FILE="{{pwd}}/age.agekey" sops "${file}"

# Headlamp admin token
get-headlamp-secret:
    kubectl -n headlamp get secret headlamp-token -o jsonpath='{.data.token}' | base64 -d
