# Managed by Ansible

canciones.poochella.club {
    # Media catalog: audio files + JSON peak data
    handle_path /media/* {
        root * {{ catalog_path_dest }}
        file_server browse

        # @cors_allowed header_regexp Origin ^(https?://canciones\.poochella\.club|http://localhost(:[0-9]+)?)$
        # header @cors_allowed Access-Control-Allow-Origin "{http.regexp.1}"
        # header @cors_allowed Vary Origin

        # JSON peak files — long immutable cache
        @json path *.json
        header @json Cache-Control "public, immutable, max-age=31536000"

        # Everything else (audio) — 6h cache with revalidation
        @notjson not path *.json
        header @notjson Cache-Control "public, must-revalidate, max-age=21600"
    }

    # SPA routing — only for paths not matched above
    handle {
        root * {{ build_path_dest }}
        try_files {path} /index.html
        file_server

        # Short cache for index.html to pick up new deploys
        @indexhtml path /index.html
        header @indexhtml Cache-Control "public, no-cache, must-revalidate, max-age=60"
    }
}

poochella.club {
    @health path /health
    respond @health "OK" 200
    respond "hello there" 200
}
