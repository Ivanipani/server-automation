#!/bin/bash
# {{ ansible_managed }}
# Rendered + launched (DETACHED, see 97-bake-publish-pve-pxe.yml) on the
# foundation PVE node. Produces the ONE SHARED Proxmox VE auto-install PXE
# artifact set for the whole hypervisor fleet:
#
#   1. download the pinned PVE ISO
#   2. patch the installer's dhclient `timeout 10;` -> `timeout {{ pve_pxe.dhcp_timeout | default(60) }};`
#      inside pve-installer.squashfs  (Proxmox bug #5583: the installer
#      fires a single ~10 s DHCP burst before a slow NIC link finishes
#      coming up after the kernel driver reset, so `from-dhcp` races and
#      fails; a 60 s timeout spans the link-up window. iPXE never drops the
#      link, which is why the iPXE stage succeeds but the installer didn't.)
#   3. rebuild a BOOTABLE ISO (El Torito + GPT recomputed for the larger
#      squashfs) using xorriso's OWN reported boot options — derived at
#      runtime so a re-pin to a new PVE version needs no edit here
#   4. `prepare-iso --fetch-from http --url {{ pve_answer_url }}
#      --pxe-loader ipxe` -> vmlinuz + initrd.img + stripped iso
#   5. drop the three artifacts (+ .sha256) into {{ pve_build_out }}/ for
#      the playbook to pct-push to bootserv01
#
# Runs detached because the CPU/IO-heavy unsquashfs/mksquashfs/prepare-iso
# saturate this mini-PC and starve sshd keepalives (a held SSH channel
# drops -> UNREACHABLE; async+become -> "could not find job"). The playbook
# polls {{ pve_build_dir }}/.done and reads {{ pve_build_dir }}/.rc.
set -uo pipefail

BUILD={{ pve_build_dir }}
OUT={{ pve_build_out }}
ISO_URL={{ pve_pxe.iso_url }}
ISO="$BUILD/{{ pve_pxe.iso_file }}"
ANSWER_URL={{ pve_answer_url }}
DHCP_TIMEOUT={{ pve_pxe.dhcp_timeout | default(60) }}
KERNEL={{ pve_pxe.kernel_file | default('vmlinuz') }}
INITRD={{ pve_pxe.initrd_file | default('initrd.img') }}
PXE_ISO={{ pve_pxe.pxe_iso_file }}
SQ=/pve-installer.squashfs

mkdir -p "$BUILD" "$OUT"
exec > "$BUILD/bake.log" 2>&1
rm -f "$BUILD/.done" "$BUILD/.rc"
cd "$BUILD"

log()  { echo; echo "=== $(date '+%H:%M:%S') $* ==="; }
fail() { echo "BAKE-FAIL: $1"; echo "${2:-1}" > "$BUILD/.rc"; touch "$BUILD/.done"; exit 1; }

log "disk free"; df -h "$BUILD" | tail -1

log "download pinned PVE ISO (if missing)"
[ -s "$ISO" ] || nice -n 19 curl -fL --retry 3 -o "$ISO" "$ISO_URL" || fail "download" 2
ls -la "$ISO"

# Proxmox ships the installer rootfs at /pve-installer.squashfs; detect it
# anyway so a layout change surfaces loudly instead of silently no-op'ing.
log "locate installer squashfs in ISO"
DET=$(xorriso -indev "$ISO" -find / -name '*.squashfs' 2>/dev/null \
        | grep -oE "/[^ ']*pve-installer\.squashfs" | head -1)
[ -n "$DET" ] && SQ="$DET"
echo "squashfs path: $SQ"

log "extract + unsquash installer squashfs"
rm -rf sqx sqroot
mkdir sqx
xorriso -osirrox on -indev "$ISO" -extract "$SQ" sqx/installer.squashfs 2>&1 | tail -2 || fail "extract-sq" 3
nice -n 19 unsquashfs -d sqroot sqx/installer.squashfs >/dev/null || fail "unsquashfs" 4

log "patch dhclient timeout -> ${DHCP_TIMEOUT}s (bug #5583)"
CONF=sqroot/etc/dhcp/dhclient.conf
[ -f "$CONF" ] || fail "dhclient.conf absent in squashfs" 5
sed -i -E "s/^[[:space:]]*timeout[[:space:]]+[0-9]+;/timeout ${DHCP_TIMEOUT};/" "$CONF"
grep -qE "^timeout ${DHCP_TIMEOUT};" "$CONF" || echo "timeout ${DHCP_TIMEOUT};" >> "$CONF"
grep -qE '^[[:space:]]*retry'        "$CONF" || echo 'retry 15;'                  >> "$CONF"
echo "--- patched dhclient.conf ---"; grep -nE 'timeout|retry' "$CONF"

log "rebuild squashfs"
rm -f new.squashfs
nice -n 19 mksquashfs sqroot new.squashfs -comp zstd -noappend >/dev/null || fail "mksquashfs" 6
rm -rf sqroot sqx
ls -la new.squashfs

log "extract full ISO tree + swap in patched squashfs"
rm -rf tree
mkdir tree
xorriso -osirrox on -indev "$ISO" -extract / tree 2>&1 | tail -2 || fail "extract-tree" 7
cp -f new.squashfs "tree${SQ}"
rm -f tree/boot/boot.cat   # regenerated by mkisofs (-c)

log "rebuild bootable ISO (boot opts derived from the source ISO)"
# xorriso reports the EXACT El Torito + GPT + grub2-mbr options that
# reproduce this ISO; we add Rock Ridge + Joliet (filesystem options the
# El Torito report omits) and rebuild so partition offsets recompute for
# the larger squashfs (a plain `-boot_image any replay` overlaps the GPT
# partitions on resize; a non-bootable data ISO makes prepare-iso fail on
# "determining the UUID").
xorriso -indev "$ISO" -report_el_torito as_mkisofs 2>/dev/null > bootopts.txt
[ -s bootopts.txt ] || fail "could not derive boot options" 8
echo "--- derived boot options ---"; cat bootopts.txt
rm -f patched.iso
eval "xorriso -as mkisofs -r -J -joliet-long $(tr '\n' ' ' < bootopts.txt) -o patched.iso tree" 2>&1 | tail -20
[ -s patched.iso ] || fail "ISO rebuild produced nothing" 9
rm -rf tree
ls -la patched.iso

log "prepare-iso (shared: fetch-from http -> answer responder)"
rm -rf pxe
mkdir pxe
nice -n 19 ionice -c3 proxmox-auto-install-assistant prepare-iso patched.iso \
  --fetch-from http --url "$ANSWER_URL" \
  --pxe-loader ipxe --output pxe 2>&1 | tail -40
PR=${PIPESTATUS[0]}
[ "$PR" -ne 0 ] && fail "prepare-iso rc=$PR" "$PR"

log "collect artifacts -> $OUT"
STRIPPED=$(ls pxe/*.iso 2>/dev/null | head -1)
[ -n "$STRIPPED" ]   || fail "prepare-iso produced no stripped iso" 10
[ -s "pxe/$KERNEL" ] || fail "prepare-iso produced no $KERNEL" 11
[ -s "pxe/$INITRD" ] || fail "prepare-iso produced no $INITRD" 12
rm -f "$OUT/$KERNEL" "$OUT/$INITRD" "$OUT/$PXE_ISO" \
      "$OUT/$KERNEL.sha256" "$OUT/$INITRD.sha256" "$OUT/$PXE_ISO.sha256"
cp -f "pxe/$KERNEL" "$OUT/$KERNEL"
cp -f "pxe/$INITRD" "$OUT/$INITRD"
cp -f "$STRIPPED"   "$OUT/$PXE_ISO"
( cd "$OUT" && for f in "$KERNEL" "$INITRD" "$PXE_ISO"; do sha256sum "$f" > "$f.sha256"; done )
ls -la "$OUT"

# Sanity: confirm the patched timeout actually rode into the published iso.
log "verify timeout in produced stripped iso"
rm -rf verify verify-root
mkdir verify
xorriso -osirrox on -indev "$OUT/$PXE_ISO" -extract "$SQ" verify/sq 2>&1 | tail -1
unsquashfs -d verify-root -n verify/sq etc/dhcp/dhclient.conf >/dev/null 2>&1 || fail "verify unsquashfs" 13
grep -qE "^timeout ${DHCP_TIMEOUT};" verify-root/etc/dhcp/dhclient.conf \
  || fail "timeout ${DHCP_TIMEOUT} missing from produced iso" 14
echo "verified: timeout ${DHCP_TIMEOUT}; present in published iso"
rm -rf verify verify-root pxe new.squashfs bootopts.txt

log "ALL GOOD"
echo 0 > "$BUILD/.rc"
touch "$BUILD/.done"
