#!ipxe
# Rendered by roles/bootserv from ansible/inventory.yaml — do not edit by hand.
# Booted via DHCP option `filename=http://bootserv01.lan/boot.ipxe` (served to
# clients whose DHCP user-class is "iPXE", i.e. chainloaded from ipxe.efi /
# undionly.kpxe). Dispatches on the booting NIC's MAC to a per-host script.

echo
echo iPXE dispatcher on ${net0/mac} (ipxe ${version})
echo

{% for name in netboot_hosts if hostvars[name].debian_netboot is defined %}
{% for m in hostvars[name].debian_netboot.boot_macs %}
iseq ${net0/mac} {{ m | lower }} && chain hosts/{{ name }}.ipxe ||
{% endfor %}
{% endfor %}

echo No MAC-based dispatch matched. Falling back to the menu.
menu Boot menu (unknown MAC ${net0/mac})
{% for name in netboot_hosts if hostvars[name].debian_netboot is defined %}
item {{ name }} Install Debian 13 on {{ name }}
{% endfor %}
item --gap -- Diagnostics
item shell  iPXE shell
item exit   Exit to firmware boot order
choose target || goto err
goto ${target}

{% for name in netboot_hosts if hostvars[name].debian_netboot is defined %}
:{{ name }}
chain hosts/{{ name }}.ipxe
{% endfor %}

:shell
shell

:exit
exit

:err
echo Dispatcher error; dropping to shell.
shell
