# {{ ansible_managed }}
# bootserv01 HTTP service: serves iPXE scripts, Debian netboot
# kernel+initrd, per-host preseeds, and per-host authorized_keys.
# Listening interface comes from bootserv_http_listen; LAN-only ACLs
# guard the sensitive paths.

server {
    listen {{ bootserv_http_listen }} default_server;
    server_name _;

    root {{ bootserv_http_root }};
    autoindex on;
    charset utf-8;

    # Per-host preseed + authorized_keys: LAN-only. Both contain
    # break-glass material (preseed has root pw hash via d-i,
    # authorized_keys is the canonical SSH key).
    location ~ ^/(preseed|keys)/ {
        allow {{ bootserv_lan_cidr }};
        deny  all;
        try_files $uri =404;
    }

    # iPXE scripts: open to the listening interface. The booting
    # initrd may not have DNS yet; restricting these would brick the
    # boot. They contain no secrets — pubkeys + preseed URLs.
    location ~ ^/(boot\.ipxe|hosts/) {
        try_files $uri =404;
    }

    # Debian netboot kernel+initrd: open. Pre-DHCP initrd fetches.
    location /debian-13/ {
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }

    # Don't leak nginx version on errors.
    server_tokens off;
}
