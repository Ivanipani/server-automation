#!/bin/sh
# Rendered by roles/bootserv from ansible/inventory.yaml — do not edit by hand.
#
# Per-host post-partman cleanup for {{ item }}, fetched + executed by the
# preseed/late_command line in /preseed/{{ item }}.cfg. Lives at:
#   http://bootserv01.lan/scripts/{{ item }}-cleanup-spare.sh
#
# What it does
# ------------
#   Re-purposes the 4th "spare" partition that partman creates per our
#   `uefi-spare` recipe (ext4 mounted /opt/spare during install) into
#   a raw partlabel-only partition ready for host-disks to pvcreate
#   into longhordata:
#     - umount /target/opt/spare
#     - drop /opt/spare from /target/etc/fstab
#     - wipefs -a on the partition to clear partman's ext4 signature
#     - sgdisk -c 4:part-alpha to set the GPT partlabel
#     - rmdir /target/opt/spare so the empty mountpoint doesn't ship
#
# Why this is a separate script (not inline in late_command):
#   The earlier inline form silently broke. d-i's /tmp doesn't
#   reliably persist the install_disk path from partman/early_command
#   into preseed/late_command, and inline multi-line shell in preseed
#   has no `set -e` and no useful error reporting — wipefs/sgdisk ran
#   with empty $INSTALL_DISK and partman's ext4 stayed on p4. This
#   script derives install_disk from `findmnt /target` (always
#   correct by the time late_command fires) and `set -e`'s the whole
#   sequence so any failure halts loudly with a banner on tty4.

set -e

LOG=/tmp/install-cleanup.log
: > "$LOG"
exec >>"$LOG" 2>&1
say() { printf '%s\n' "$*" >>"$LOG"; printf '%s\n' "$*" >/dev/tty4 2>/dev/null || true; }

say "===== $(date) cleanup-spare for {{ item }} ====="

# Derive install_disk from /target's root mount. partman has /target
# mounted by the time late_command fires, so PKNAME gives us the disk
# regardless of whether early_command saved /tmp/install_disk.path.
ROOT_SRC=$(findmnt -no SOURCE /target)
if [ -z "$ROOT_SRC" ]; then
    say "FATAL: /target not mounted; findmnt /target returned empty"
    exit 1
fi
say "  /target root source: $ROOT_SRC"

INSTALL_DISK_NAME=$(lsblk -no PKNAME "$ROOT_SRC" | head -1)
if [ -z "$INSTALL_DISK_NAME" ]; then
    say "FATAL: could not derive install disk from $ROOT_SRC"
    exit 1
fi
INSTALL_DISK="/dev/$INSTALL_DISK_NAME"
say "  install_disk: $INSTALL_DISK"

# p4 path differs for sd*/nvme*/mmc*. NVMe + mmcblk need the 'p'
# separator before the partition number (e.g. nvme0n1p4).
case "$INSTALL_DISK" in
    *nvme*|*mmc*|*loop*) P4="${INSTALL_DISK}p4" ;;
    *)                    P4="${INSTALL_DISK}4"   ;;
esac
say "  spare partition: $P4"

if [ ! -b "$P4" ]; then
    say "FATAL: $P4 is not a block device — partman recipe didn't create p4?"
    exit 1
fi

# Unmount the spare from /target. If it wasn't mounted (some d-i builds
# don't auto-mount filesystems whose mountpoints don't exist yet in the
# new root), that's fine — we just need it not-mounted for wipefs.
say "  umount /target/opt/spare"
if mountpoint -q /target/opt/spare 2>/dev/null; then
    umount /target/opt/spare
else
    say "    (was not mounted)"
fi

# Strip the /opt/spare fstab line so the installed system doesn't try
# to mount a now-wiped partition on first boot.
say "  sed -i strip /opt/spare from /target/etc/fstab"
sed -i '\#[[:space:]]/opt/spare[[:space:]]#d' /target/etc/fstab

# Clear partman's install-time ext4 superblock so host-disks's
# pvcreate doesn't refuse the partition with "foreign signatures".
say "  wipefs -a $P4 (clear partman's ext4 signature)"
wipefs -a "$P4"

# Set the GPT partlabel so /dev/disk/by-partlabel/part-alpha resolves
# to this partition on every boot.
say "  sgdisk -c 4:part-alpha $INSTALL_DISK"
sgdisk -c 4:part-alpha "$INSTALL_DISK"

say "  partx -u + udevadm settle"
# partx (BLKPG) over partprobe (BLKRRPART): BLKRRPART is refused on
# a disk with active partitions (which $INSTALL_DISK always has at
# this point — partman just mounted root from p3). Same reason
# host-disks's _carve_one.yml uses partx instead of partprobe.
partx -u "$INSTALL_DISK"
udevadm settle

# Remove the now-empty mountpoint from the installed system. If for
# some reason the dir isn't empty (image-baseline.sh hasn't run yet,
# so /opt/spare should be empty), keep it — rmdir will just refuse.
say "  rmdir /target/opt/spare"
rmdir /target/opt/spare 2>/dev/null || say "    (rmdir refused — non-empty)"

# Sanity dump so the operator can verify on tty4 (Alt+F4).
say ""
say "Final GPT layout on $INSTALL_DISK:"
sgdisk -p "$INSTALL_DISK" 2>&1 | tail -10 >>"$LOG"
sgdisk -p "$INSTALL_DISK" 2>&1 | tail -10 >/dev/tty4 2>/dev/null || true

say ""
say "by-partlabel symlinks:"
ls -la /dev/disk/by-partlabel/ 2>&1 | tee -a "$LOG" >/dev/tty4 2>/dev/null || true

say ""
say "===== cleanup-spare done at $(date) ====="
exit 0
