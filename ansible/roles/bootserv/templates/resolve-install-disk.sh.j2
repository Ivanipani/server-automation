#!/bin/sh
# Rendered by roles/bootserv from ansible/inventory.yaml — do not edit by hand.
#
# Per-host install-disk resolver for {{ item }}, fetched + executed by the
# `partman/early_command` line in /preseed/{{ item }}.cfg. Lives at:
#   http://bootserv01.lan/scripts/{{ item }}-resolve-install-disk.sh
#
# What it does
# ------------
#   1. Walks /sys/block (NOT lsblk — d-i's stripped util-linux ships
#      neither lsblk nor PKNAME, and sysfs is the canonical kernel
#      source anyway).
#   2. Matches one disk against the inventory hw pin (model + serial)
#      from storage.disks[?select == 'boot'].hw.{model, serial}.
#   3. Wipes the partition table on the resolved disk (dd-zero first
#      10 MiB + last 64 KiB, then blockdev --rereadpt). The wipe is
#      deliberately MINIMAL — just enough to kill the primary GPT
#      (sectors 1-33) + MBR + LVM PV label/metadata + backup GPT
#      (last 33 sectors), so partman starts from a blank partition
#      table. The OS-managed area (first ~100 GiB) is then wiped by
#      partman's own format step; sectors past 100 GiB are NEVER
#      touched by the preseed — that region is owned by the host-disks
#      role post-install. The hw pin is the only safety: only the
#      exact disk pinned in inventory is wiped; siblings on the host
#      are never touched.
#   4. Writes the resolved /dev path into partman-auto/disk and
#      grub-installer/bootdev via debconf, so the partitioner + grub
#      installer pick it up moments later.
#
# Tooling: d-i's stripped runtime reliably ships dd, blockdev,
# blkdiscard, swapoff, mkswap, mount/umount, find, ls, cat, awk, sed.
# It does NOT ship wipefs, lsblk, sgdisk, pvremove, vgchange. Earlier
# versions of this script tried to use all of those with "skip if not
# present" guards — the guards silently masked the fact that wipefs
# and partprobe never ran on real hardware. This rewrite uses only
# dd + blockdev (both confirmed present).
#
# Logging
# -------
#   * Full log → /tmp/install-resolver.log (survives until reboot).
#   * Progress + critical messages also tee'd to /dev/tty4 — that's
#     d-i's syslog console (Alt+F4 from the main install screen).
#   * Critical failure banners also tee'd to /dev/kmsg so they show
#     in dmesg too (also Alt+F4).
#
# On failure
# ----------
#   exit 1 → partman/early_command propagates the failure, d-i shows
#   its standard "command failed" dialog on tty1 (the install screen)
#   and waits for input. That's the LOUD signal the operator needs.
#   While d-i is parked at that dialog:
#     - Alt+F4: read the resolver log on the d-i syslog console
#     - Alt+F2: busybox shell  →  cat /tmp/install-resolver.log
#     - Alt+F1: back to the install screen
#   Earlier versions sleep'd 1h here — that masked the failure (no
#   loud dialog, just a hung progress bar) and made it easy to walk
#   away thinking the install was still working.

set -e

# These come from inventory: storage.disks[?select == 'boot'].hw
EXPECTED_MODEL='{{ _hw.model }}'
EXPECTED_SERIAL='{{ _hw.serial }}'
LOG=/tmp/install-resolver.log

# All our output goes to the log; `say` ALSO mirrors to tty4 so the
# operator can watch progress on Alt+F4 in real time.
: > "$LOG"
exec >>"$LOG" 2>&1
say() { printf '%s\n' "$*" >>"$LOG"; printf '%s\n' "$*" >/dev/tty4 2>/dev/null || true; }

say "===== $(date) resolve-install-disk for {{ item }} ====="
say "expected: model='$EXPECTED_MODEL' serial='$EXPECTED_SERIAL'"
say "log: $LOG"
say ""

say "--- /proc/partitions ---"
cat /proc/partitions >>"$LOG" 2>&1 || true
cat /proc/partitions >/dev/tty4 2>/dev/null || true
say ""

# Walk /sys/block — every block device the kernel exposes has a
# directory here, with `device/model` + `device/serial` populated for
# real disks (SATA / NVMe / SAS / USB). Loop / ramdisk / device-mapper
# / RAID / CD aren't candidates.
say "--- sysfs candidates ---"
install_disk=""
for d in /sys/block/*; do
    bn=${d##*/}
    case "$bn" in
        loop*|ram*|sr*|fd*|dm-*|md*) continue ;;
    esac
    if [ ! -r "$d/device/model" ]; then
        say "  skip /dev/$bn  (no /sys/block/$bn/device/model)"
        continue
    fi
    m=$(tr -d ' \t\r\n' < "$d/device/model")
    s=""
    [ -r "$d/device/serial" ] && s=$(tr -d ' \t\r\n' < "$d/device/serial")
    say "  candidate: /dev/$bn  model='$m'  serial='$s'"
    if [ "$m" = "$EXPECTED_MODEL" ] && [ "$s" = "$EXPECTED_SERIAL" ]; then
        install_disk="/dev/$bn"
        break
    fi
done

if [ -z "$install_disk" ]; then
    say ""
    say "FATAL: no /sys/block disk matches inventory hw pin"
    BANNER="
================================================================
  INSTALL HALTED on {{ item }}

  >>> DEBUG: press these keys (top-row Fn keys on the host) <<<
       Alt+F2  →  busybox shell
                    cat $LOG
                    cat /proc/partitions
                    for d in /sys/block/*; do
                      echo \$d \$(cat \$d/device/model 2>/dev/null) \\
                                \$(cat \$d/device/serial 2>/dev/null)
                    done
       Alt+F4  →  d-i syslog console (this banner)
       Alt+F1  →  back to the install screen

  resolver could not find a disk matching the inventory hw pin:
    expected model='$EXPECTED_MODEL'
    expected serial='$EXPECTED_SERIAL'

  Fix: update storage.disks[0].hw in ansible/inventory.yaml with the
       model + serial of one of the candidates above (whitespace-
       stripped), then \`just do-bootserv-config\` on the control node
       and reboot the host.

  Exiting non-zero so partman fails loudly (d-i dialog on tty1)
  instead of hanging the install indefinitely.
================================================================
"
    printf '%s' "$BANNER" >>"$LOG"
    printf '%s' "$BANNER" >/dev/tty4 2>/dev/null || true
    printf '%s' "$BANNER" >/dev/kmsg 2>/dev/null || true
    exit 1
fi

say ""
say "RESOLVED install_disk=$install_disk"

# ============================================================
# Wipe the partition table on $install_disk before partman runs.
#
# Why: the host may carry an old partition table from a prior install
# (Proxmox LVM-thin pool, prior Debian root LVM, an NVMe swapped in
# from another host). Partman would otherwise refuse to silently
# overwrite existing PV/VG signatures and halt at a dialog. The
# (model, serial) hw pin resolved above is the only safety: we touch
# ONLY $install_disk, never a sibling.
#
# Scope: MINIMAL. Just the partition table at the head + tail —
# enough to make partman see a blank slate. Partman's own format step
# wipes the OS-managed area (first ~100 GiB) as a side-effect of
# creating p1-p3. Sectors past 100 GiB are NEVER touched by the
# preseed; that region is owned by the host-disks role post-install.
#
# What gets killed:
#   - GPT primary header   (sectors 1-33)
#   - MBR                  (first 512 B)
#   - LVM2 PV label        (sector 1)
#   - LVM2 metadata area   (first ~1 MiB; 10 MiB is generous)
#   - GPT backup header    (last 33 sectors)
#
# Tooling: dd + blockdev only — both are reliably present in d-i's
# stripped runtime. The previous version of this script attempted
# blkdiscard / wipefs / partprobe with "skip if not present" guards;
# those tools are silently absent in d-i, so the guards just masked
# no-ops. dd-zeroing the header sectors is the canonical fallback
# and what wipefs would have done anyway for our targets.
# ============================================================
say ""
say "--- wiping $install_disk partition table ---"

# Head: 10 MiB covers GPT primary (16 KiB at LBA 1) + MBR + LVM PV
# label + first LVM metadata area (default 1 MiB) with room to spare.
say "  dd zero first 10 MiB"
dd if=/dev/zero of="$install_disk" bs=1M count=10 conv=fsync >>"$LOG" 2>&1

# Tail: 128 sectors (64 KiB) covers the GPT backup header (last 33
# sectors). Tight scope so we don't touch the data region past
# 100 GiB. If we left the backup intact, parted/partman would
# detect the corrupted primary and restore the OLD layout from it.
SECTORS=$(blockdev --getsz "$install_disk")
TAIL_START=$((SECTORS - 128))
say "  dd zero last 64 KiB (seek=$TAIL_START sectors, count=128)"
dd if=/dev/zero of="$install_disk" bs=512 seek=$TAIL_START \
   count=128 conv=fsync >>"$LOG" 2>&1

# Force the kernel to drop its cached partition table so partman
# sees the (now empty) layout, not whatever was there at boot.
say "  re-read partition table"
blockdev --rereadpt "$install_disk" >>"$LOG" 2>&1

say "  wipe complete"
say ""

# Prefer the canonical d-i confmodule API (`db_set` via
# debconf-communicate); fall back to the `debconf-set` shell wrapper
# if confmodule isn't on disk. One of these is always present in d-i.
if [ -r /usr/share/debconf/confmodule ]; then
    # shellcheck disable=SC1091
    . /usr/share/debconf/confmodule
    db_set partman-auto/disk "$install_disk"
    db_set grub-installer/bootdev "$install_disk"
    say "  set via db_set (confmodule)"
elif command -v debconf-set >/dev/null 2>&1; then
    debconf-set partman-auto/disk "$install_disk"
    debconf-set grub-installer/bootdev "$install_disk"
    say "  set via debconf-set wrapper"
else
    say "FATAL: no debconf write path available (no confmodule, no debconf-set)"
    say "  debug: Alt+F2 = busybox shell  |  Alt+F4 = d-i syslog  |  Alt+F1 = install screen"
    exit 1
fi

# Sanity-verify the value actually landed in debconf.
if command -v debconf-get >/dev/null 2>&1; then
    say "  verify: partman-auto/disk=$(debconf-get partman-auto/disk 2>/dev/null || echo '?')"
    say "  verify: grub-installer/bootdev=$(debconf-get grub-installer/bootdev 2>/dev/null || echo '?')"
fi

# Persist the resolved install_disk path to a known file so the
# preseed/late_command (which runs in a separate process after partman
# finishes) can pick it up. d-i's /tmp survives across the early- and
# late-command boundaries within a single install session.
echo "$install_disk" > /tmp/install_disk.path
say "  install_disk persisted to /tmp/install_disk.path for late_command"

say "===== resolver done at $(date) ====="
exit 0
