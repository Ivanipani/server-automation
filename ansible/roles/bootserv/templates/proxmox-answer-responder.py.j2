#!/usr/bin/env python3
# {{ ansible_managed }}
# Proxmox VE auto-install answer responder.
#
# The PVE installer fetches its answer over HTTP by POSTing a JSON blob
# of system info (DMI + every NIC's MAC) to the --url baked into
# initrd.img (http://bootserv01.lan/proxmox-answer, reverse-proxied here
# by Caddy). We match any POSTed MAC against mac-map.json and return that
# host's <host>.toml. This is what makes ONE shared vmlinuz/initrd.img
# serve the whole fleet: per-host selection lives entirely here.
#
# Rendered by roles/bootserv. Bound to localhost; Caddy fronts it with
# the LAN-only ACL. Pure stdlib — no third-party deps on bootserv01.

import json
import re
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

LISTEN_HOST = "127.0.0.1"
LISTEN_PORT = {{ bootserv_pve_responder_port }}
ANSWERS_DIR = "{{ bootserv_pve_answers_dir }}"
MAC_MAP = ANSWERS_DIR + "/mac-map.json"

_MAC_RE = re.compile(r"([0-9a-fA-F]{2}[:-]){5}[0-9a-fA-F]{2}")


def _norm(mac):
    """Lowercase, strip separators → 12 hex chars."""
    return re.sub(r"[^0-9a-f]", "", mac.lower())


def _macs_from_request(body):
    """Collect every MAC in the POSTed sysinfo, defensively.

    Primary source is the documented `network_interfaces[].mac`, but we
    also regex-scan the raw body so a schema tweak upstream can't silently
    break matching.
    """
    macs = set()
    try:
        data = json.loads(body.decode("utf-8"))
        for nic in data.get("network_interfaces", []) or []:
            mac = nic.get("mac") or nic.get("address")
            if mac:
                macs.add(_norm(mac))
    except (ValueError, AttributeError):
        pass
    # Belt-and-suspenders: regex-scan the raw body for any MAC literal.
    for m in _MAC_RE.finditer(body.decode("utf-8", "ignore")):
        macs.add(_norm(m.group(0)))
    return macs


def _load_map():
    with open(MAC_MAP, "r", encoding="utf-8") as fh:
        # keys are already normalized (lowercase, no separators)
        return {_norm(k): v for k, v in json.load(fh).items()}


class Handler(BaseHTTPRequestHandler):
    server_version = ""  # don't leak identity

    def _answer(self, host):
        path = ANSWERS_DIR + "/" + host + ".toml"
        try:
            with open(path, "rb") as fh:
                payload = fh.read()
        except OSError:
            self.send_error(404, "no answer file for matched host")
            return
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0) or 0)
        body = self.rfile.read(length) if length else b""
        try:
            mac_map = _load_map()
        except OSError:
            self.send_error(503, "mac-map.json not available")
            return
        for mac in _macs_from_request(body):
            if mac in mac_map:
                self.log_message("matched MAC %s -> %s", mac, mac_map[mac])
                self._answer(mac_map[mac])
                return
        self.log_message("no MAC match among %d candidates", len(_macs_from_request(body)))
        self.send_error(404, "no answer for any posted MAC")

    # Some installer builds probe with GET first; 405 is informative.
    def do_GET(self):
        self.send_error(405, "POST sysinfo to receive an answer")

    def log_message(self, fmt, *args):
        sys.stderr.write("proxmox-answer-responder: " + (fmt % args) + "\n")


def main():
    httpd = ThreadingHTTPServer((LISTEN_HOST, LISTEN_PORT), Handler)
    sys.stderr.write(
        "proxmox-answer-responder: listening on %s:%d, answers in %s\n"
        % (LISTEN_HOST, LISTEN_PORT, ANSWERS_DIR)
    )
    httpd.serve_forever()


if __name__ == "__main__":
    main()
