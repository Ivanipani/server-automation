# Debian 13 (Trixie) preseed for {{ item }}
# Rendered by roles/bootserv from ansible/inventory.yaml — do not edit by hand.
# Served at http://bootserv01.lan/preseed/{{ item }}.cfg (LAN-only) and loaded
# by d-i via preseed/url= on the kernel cmdline (see hosts/{{ item }}.ipxe).

### Localization
d-i debian-installer/locale string en_US.UTF-8
d-i keyboard-configuration/xkb-keymap select us

### Network — resolved by preseed/early_command BEFORE netcfg runs.
### Static IP comes from the OPNsense reservation tied to the cabled
### NIC's MAC, but DHCP is done by `resolve-install-iface.sh` (fetched
### from bootserv01), not by netcfg. The resolver:
###   1. brings every real NIC up,
###   2. waits up to 30s for any NIC to show carrier,
###   3. udhcpc-grabs a lease on that NIC,
###   4. db_set's netcfg/disable_autoconfig=true + every netcfg/get_*
###      so netcfg runs in MANUAL mode (it just applies our values,
###      never touches the PHY).
### Why this is the durable port-agnostic fix: netcfg's own auto flow
### does an `ip link set down/up` cycle between picking an interface
### and starting DHCP, and slow SFP+/DAC PHYs (Mellanox CX4,
### Realtek 2.5G, Broadcom NetXtreme) take 5–10s to re-link after
### that cycle. With auto, whether netcfg succeeds depends on which
### NIC is cabled — i.e. which PHY is asked to race a fixed timeout.
### Resolving once in early_command, on a warm PHY, removes the race.
### The link_wait_timeout / dhcp_timeout bumps below are belt-and-
### suspenders: if early_command bails for any reason and netcfg
### falls back to its own DHCP, the bumped timeouts give slow PHYs
### the room they need. The choose_interface=auto fallback is the
### same — used only if disable_autoconfig wasn't flipped.
###
### Both values are preseed-time only; the installed system uses its
### own NetworkManager/ifupdown configuration.
d-i preseed/early_command string \
    set -e; \
    URL=http://bootserv01.lan/scripts/resolve-install-iface.sh; \
    SCRIPT=/tmp/resolve-install-iface.sh; \
    if ! wget -q -O "$SCRIPT" "$URL"; then \
        echo "WARN: could not fetch $URL — falling back to netcfg auto" >/dev/tty4; \
    else \
        sh "$SCRIPT" || echo "WARN: resolver exited non-zero — falling back to netcfg auto" >/dev/tty4; \
    fi
d-i netcfg/choose_interface select auto
d-i netcfg/link_wait_timeout string 30
d-i netcfg/dhcp_timeout string 60
d-i netcfg/hostname string {{ item }}
d-i netcfg/get_hostname string {{ item }}
d-i netcfg/get_domain string {{ hostvars[item].domain | default(domain | default('lan')) }}
d-i netcfg/wireless_wep string

### Mirror
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

### Accounts — d-i creates NOTHING durable here. The late_command
### wgets + executes the canonical image-baseline.sh from bootserv01,
### which creates the `ansible` (key-only) + `tourmanager` (password-
### only break-glass) accounts and explicitly locks root. Same script
### the VM bake, LXC bake, and PVE first-boot run — single source of
### truth.
###
### Why a throwaway root password is preseeded: Trixie's user-setup
### refuses to skip BOTH root login AND regular-user creation in the
### same run (no usable login would remain), so setting both
### `passwd/root-login false` + `passwd/make-user false` causes the
### installer to fall back to interactive user-account prompts despite
### `make-user=false`. Giving root a known temp password satisfies
### user-setup non-interactively; image-baseline.sh's `usermod -L root`
### locks the account before first boot completes (and also wipes any
### root authorized_keys). Net effect on the running host is identical
### to leaving root unset, with no install-time prompts.
d-i passwd/root-login boolean true
d-i passwd/root-password password install-temp-locked-by-late-command
d-i passwd/root-password-again password install-temp-locked-by-late-command
d-i passwd/make-user boolean false

### Clock
d-i clock-setup/utc boolean true
d-i time/zone string {{ bootserv_timezone }}
d-i clock-setup/ntp boolean true

### Partitioning — three fixed-size OS partitions on the inventory-
### marked boot disk; everything past 100 GiB is left as free space
### for the post-install host-disks role to carve. Every other disk
### on the host is also left untouched.
###
### Install target resolution: the boot disk is pinned in inventory by
### `storage.disks[?select == 'boot'].hw.{model, serial}` (single
### source of truth — no parallel `install_disk` field). The
### `partman/early_command` below walks /sys/block at install time and
### writes the matching /dev path into the partman-auto/disk and
### grub-installer/bootdev debconf settings, which the partitioner +
### grub installer pick up moments later. Resolving at install time
### (instead of templating a kernel name like `/dev/nvme0n1`) is
### robust against re-cabling, NVMe slot order, and the SATA/NVMe
### mix that varies host-to-host. Hook choice matters: per the
### Debian preseed manual, `preseed/early_command` runs before
### partman's disk discovery, while `partman/early_command` is "run
### just before the partitioner starts" and is the documented hook
### for dynamic partitioner preseeding that depends on disk state.
###
### Disk-state preconditions: NONE. The resolver dd-zeroes the
### partition table on the resolved disk (first 10 MiB + last 64 KiB)
### so partman sees a blank slate, even after a re-image or an NVMe
### swap from another host. The wipe is MINIMAL — partman's format
### step does the real wipe of the OS-managed 100 GiB. Sectors past
### 100 GiB are NEVER touched by the preseed; that region is owned
### by the host-disks role post-install. The hw pin is the only
### safety: only the exact disk pinned in inventory is wiped;
### siblings on the host are never touched.
d-i partman/early_command string \
    set -e; \
    URL=http://bootserv01.lan/scripts/{{ item }}-resolve-install-disk.sh; \
    SCRIPT=/tmp/resolve-install-disk.sh; \
    if ! wget -q -O "$SCRIPT" "$URL"; then \
        echo "FATAL: could not fetch $URL" >/dev/tty4; \
        echo "  debug: Alt+F2 = busybox shell  |  Alt+F4 = d-i syslog  |  Alt+F1 = install screen" >/dev/tty4; \
        exit 1; \
    fi; \
    sh "$SCRIPT"

# The two debconf values below are placeholders — the early_command
# above rewrites them at install time. They are still preseeded so
# that if the early_command failed silently, partman would refuse
# (no matching disk) rather than auto-picking one and wiping it.
d-i partman-auto/disk string /dev/__resolved_by_early_command__
d-i partman-auto/method string regular

# Three-partition layout — totals exactly 100 GiB. The rest of the
# disk is left as free space in the GPT; the host-disks role creates
# p4 + the data-pool LVM thinpool post-install from inventory's
# storage.disks[?select == 'boot'].partitions declaration. Keeping
# the data-partition layout off the preseed and onto host-disks means
# the area past 100 GiB is NEVER touched by the installer — survives
# re-images cleanly (provided host-disks' "boot disk: never wipe,
# only carve" rule holds, which is its existing default).
#
# Recipe format per partition: `min priority max fs_type` then options.
#   - p1 ESP:    538/538/538 vfat, method{ efi }, /boot/efi.
#                Fixed size (min=max).
#   - p2 swap:   4096/4096/4096 linux-swap, no mountpoint.
#                Fixed size; modest swap as OOM cushion.
#   - p3 root:   102400/102400/102400 ext4, /. Fixed size.
#
# Watch-out (revisit if observed on first re-image): earlier versions
# of this recipe added a 4th "spare" partition with max=-1 specifically
# to absorb the remainder, on the theory that partman has a quirk of
# growing the LAST partition past its declared max even when min=max.
# With p3 here set min=priority=max=102400, partman SHOULD respect the
# cap. If p3 ends up > 100 GiB on first re-image, the fallback is to
# re-add a nominal 1 MiB p4 with method{ keep } (no format).
d-i partman-auto/expert_recipe string                                       \
      uefi-3p ::                                                             \
          538 538 538 free                                                   \
              $iflabel{ gpt }                                                \
              $reusemethod{ }                                                \
              method{ efi }                                                  \
              format{ }                                                      \
          .                                                                  \
          4096 4096 4096 linux-swap                                          \
              $primary{ }                                                    \
              method{ swap }                                                 \
              format{ }                                                      \
          .                                                                  \
          102400 102400 102400 ext4                                          \
              $primary{ }                                                    \
              method{ format }                                               \
              format{ }                                                      \
              use_filesystem{ }                                              \
              filesystem{ ext4 }                                             \
              mountpoint{ / }                                                \
          .

d-i partman-auto/choose_recipe select uefi-3p

d-i partman-partitioning/choose_label string gpt
d-i partman-partitioning/default_label string gpt
d-i partman/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

### Apt
d-i apt-setup/non-free boolean false
d-i apt-setup/non-free-firmware boolean true
d-i apt-setup/contrib boolean false
d-i apt-setup/services-select multiselect security, updates

### Packages — minimal base + SSH; the rest is Ansible's job.
tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string openssh-server python3 sudo curl ca-certificates gnupg
d-i pkgsel/upgrade select full-upgrade
d-i pkgsel/update-policy select none
popularity-contest popularity-contest/participate boolean false

### Bootloader
d-i grub-installer/only_debian boolean true
d-i grub-installer/with_other_os boolean true
d-i grub-installer/bootdev string /dev/__resolved_by_early_command__

### Finish
d-i finish-install/reboot_in_progress note

### Late command — wget + bash the canonical image-baseline.sh from
### bootserv01 inside the installed-system chroot via `in-target`.
### Same script the VM bake, LXC bake, and PVE first-boot run —
### single source of truth (users, sshd hardening, apt-no-auto-
### upgrades, root lock). See group_vars/all/image-baseline.yml.
###
### The script contains the vault-derived tourmanager password
### hash, so it's `rm`'d in the same compound after it executes —
### only the resulting /etc/shadow entry persists on the installed
### host.
d-i preseed/late_command string \
    set -e ; \
    in-target wget -qO /var/tmp/image-baseline.sh http://bootserv01.lan/scripts/image-baseline.sh ; \
    in-target bash /var/tmp/image-baseline.sh ; \
    in-target rm /var/tmp/image-baseline.sh
