# Debian 13 (Trixie) preseed for {{ item }}
# Rendered by roles/bootserv from ansible/inventory.yaml — do not edit by hand.
# Served at http://bootserv01.lan/preseed/{{ item }}.cfg (LAN-only) and loaded
# by d-i via preseed/url= on the kernel cmdline (see hosts/{{ item }}.ipxe).

### Localization
d-i debian-installer/locale string en_US.UTF-8
d-i keyboard-configuration/xkb-keymap select us

### Network — DHCP. Static IP comes from the OPNsense reservation tied
### to the booting NIC's MAC.
d-i netcfg/choose_interface select auto
d-i netcfg/hostname string {{ item }}
d-i netcfg/get_hostname string {{ item }}
d-i netcfg/get_domain string {{ hostvars[item].domain | default(domain | default('lan')) }}
d-i netcfg/wireless_wep string

### Mirror
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

### Accounts — `ansible` (key, automation) + `tourmanager` (password,
### break-glass) are created in late_command. They are the install-time
### GUARANTEE that every freshly-netbooted Debian host has equal-shape
### ansible + break-glass access, independent of any later host-base run.
### Root is LOCKED — no password is set, the late_command drops a
### `PermitRootLogin no` sshd config, and `sudo` from ansible/tourmanager
### is the only path to root (matching the fleet-wide no-root-SSH policy
### later enforced by the ssh-hardening role).
d-i passwd/root-login boolean false
d-i passwd/make-user boolean false

### Clock
d-i clock-setup/utc boolean true
d-i time/zone string {{ bootserv_timezone }}
d-i clock-setup/ntp boolean true

### Partitioning — whole-disk LVM on the inventory-declared install
### disk. Every other disk on the host is left untouched (free for the
### post-install host-disks role to carve, if applicable).
###
### ASSUMPTION: the install disk is BLANK at install time. We assume
### the operator has wiped it out-of-band — either via the host's BIOS
### secure-erase feature or `dd`/`blkdiscard` from a rescue env —
### before triggering the PXE install. This preseed deliberately does
### NOT include a `preseed/early_command` to zero the disk + write a
### fresh GPT label. The earlier attempt to do so via d-i's stripped
### initrd was unreliable (no `wipefs`/`sgdisk`, partman caching the
### old layout before `partman/early_command` fires, etc.) and the
### out-of-band wipe is faster, more thorough, and removes the partman
### "refuses to overwrite" gate cleanly. If you need to install on a
### dirty disk in the future, restore the early_command block from
### git history.

d-i partman-auto/disk string {{ hostvars[item].debian_netboot.install_disk }}
d-i partman-auto/method string lvm
d-i partman-lvm/device_remove_lvm boolean true
d-i partman-md/device_remove_md boolean true
d-i partman-lvm/confirm boolean true
d-i partman-lvm/confirm_nooverwrite boolean true
d-i partman-auto-lvm/new_vg_name string system
d-i partman-auto-lvm/guided_size string max
# Suppress the legacy "no separate /boot with LVM" warning. The
# concern dates from grub-pc not being able to read LVM, so /boot
# had to be plain ext4 outside LVM. grub-efi-amd64 (what UEFI
# installs use) reads ext4-inside-LVM natively, so /boot can live in
# the root LV. The warning is partman being conservative; we ack it.
d-i partman-auto-lvm/no_boot boolean true

# Custom partman recipe: ESP (outside LVM) + swap LV + root LV.
# Stock `atomic` produces only one partition for / and doesn't include
# an EFI System Partition, and partman's UEFI auto-add-ESP logic
# doesn't reliably fire under method=lvm — the result is a layout
# with no mountable root ("no root file system" / "partition too
# small" at install time). This explicit recipe avoids the ambiguity.
#
# Recipe format per partition: `min priority max fs_type` then options.
#   - ESP:   538/538/1075 MiB FAT32, `method{ efi }`, NOT in LVM
#   - swap:  1-4 GiB inside LVM, sized at 200% of RAM via priority
#   - root:  ≥4 GiB inside LVM, priority high + max=-1 → takes the rest
#
# `$iflabel{ gpt }` ensures the ESP entry only fires on GPT disks
# (which our preseed/early_command guarantees via parted mklabel gpt).
# `$defaultignore{ }` keeps swap+root out of the default partition
# list — they only materialize via the LVM mechanism.
# `$lvmok{ }` tells partman to allocate this partition inside the LVM
# PV rather than as a standalone primary.
d-i partman-auto/expert_recipe string                                       \
      uefi-lvm-system ::                                                     \
          538 538 1075 free                                                  \
              $iflabel{ gpt }                                                \
              $reusemethod{ }                                                \
              method{ efi }                                                  \
              format{ }                                                      \
          .                                                                  \
          1024 4096 200% linux-swap                                          \
              $defaultignore{ }                                              \
              $lvmok{ }                                                      \
              lv_name{ swap }                                                \
              method{ swap }                                                 \
              format{ }                                                      \
          .                                                                  \
          4096 10000 -1 ext4                                                 \
              $defaultignore{ }                                              \
              $lvmok{ }                                                      \
              lv_name{ root }                                                \
              method{ format }                                               \
              format{ }                                                      \
              use_filesystem{ }                                              \
              filesystem{ ext4 }                                             \
              mountpoint{ / }                                                \
          .

d-i partman-auto/choose_recipe select uefi-lvm-system

d-i partman-partitioning/choose_label string gpt
d-i partman-partitioning/default_label string gpt
d-i partman/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

### Apt
d-i apt-setup/non-free boolean false
d-i apt-setup/non-free-firmware boolean true
d-i apt-setup/contrib boolean false
d-i apt-setup/services-select multiselect security, updates

### Packages — minimal base + SSH; the rest is Ansible's job.
tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string openssh-server python3 sudo curl ca-certificates gnupg
d-i pkgsel/upgrade select full-upgrade
d-i pkgsel/update-policy select none
popularity-contest popularity-contest/participate boolean false

### Bootloader
d-i grub-installer/only_debian boolean true
d-i grub-installer/with_other_os boolean true
d-i grub-installer/bootdev string {{ hostvars[item].debian_netboot.install_disk }}

### Finish
d-i finish-install/reboot_in_progress note

### Late command — create the two guaranteed-access accounts and mask
### unattended-upgrades to match the rest of the fleet's "patching is
### deliberate" policy.
###
###   ansible      → key-only automation account, NOPASSWD sudo. Pubkey
###                  is fetched over HTTP from this same bootserv
###                  (LAN-ACL'd by nginx) so we avoid escaping it inside
###                  this single-line directive.
###   tourmanager  → password-only break-glass account, NOPASSWD sudo.
###                  Hash is computed by Ansible with a deterministic
###                  per-host salt so re-rendering this template is
###                  idempotent (no spurious `changed:` on the file).
###                  Plaintext never reaches disk: useradd -p takes the
###                  crypt(3) hash directly, which is shell-safe.
###
### Both are also created/reconciled later by host-base on every
### Ansible run; the preseed copies exist so a freshly-installed Debian
### node has them BEFORE any play touches it.
{% set _tm_salt = (item ~ '-tourmanager-salt-v1') | hash('sha256') %}
{% set _tm_salt = _tm_salt[:16] %}
{% set _tm_hash = bootserv_tourmanager_password | password_hash('sha512', _tm_salt) %}
d-i preseed/late_command string \
    in-target useradd -m -s /bin/bash -G sudo ansible ; \
    in-target install -d -o ansible -g ansible -m 0700 /home/ansible/.ssh ; \
    in-target wget -qO /home/ansible/.ssh/authorized_keys http://bootserv01.lan/keys/{{ item }}.pub ; \
    in-target chown ansible:ansible /home/ansible/.ssh/authorized_keys ; \
    in-target chmod 0600 /home/ansible/.ssh/authorized_keys ; \
    in-target sh -c 'echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible' ; \
    in-target chmod 0440 /etc/sudoers.d/ansible ; \
    in-target useradd -m -s /bin/bash -G sudo -p '{{ _tm_hash }}' tourmanager ; \
    in-target sh -c 'echo "tourmanager ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/tourmanager' ; \
    in-target chmod 0440 /etc/sudoers.d/tourmanager ; \
    in-target sh -c 'echo "PermitRootLogin no" > /etc/ssh/sshd_config.d/00-no-root.conf' ; \
    in-target chmod 0644 /etc/ssh/sshd_config.d/00-no-root.conf ; \
    in-target sh -c 'echo "APT::Periodic::Update-Package-Lists \"0\";" > /etc/apt/apt.conf.d/99-no-auto-upgrades' ; \
    in-target sh -c 'echo "APT::Periodic::Unattended-Upgrade \"0\";" >> /etc/apt/apt.conf.d/99-no-auto-upgrades' ; \
    in-target systemctl mask apt-daily.timer apt-daily-upgrade.timer
