# UEFI auto-install boot config for {{ target_host }}.
# Replaces boot/grub/grub.cfg in the rebuilt ISO. The default entry boots
# the installer non-interactively against /cdrom/preseed.cfg.
#
# `priority=critical` suppresses every prompt that has any preseed-friendly
# default; the few questions that are unconditionally asked (locale, keymap)
# are answered on the kernel cmdline so d-i never blocks for input.

if loadfont $prefix/font.pf2 ; then
  set gfxmode=auto
  insmod efi_gop
  insmod efi_uga
  insmod gfxterm
  terminal_output gfxterm
fi

set timeout=3
set default=0

menuentry --hotkey=a "Auto-install Debian 13 ({{ target_host }})" {
    set background_color=black
    linux    /install.amd/vmlinuz auto=true priority=critical \
             preseed/file=/cdrom/preseed.cfg \
             locale=en_US.UTF-8 keymap=us \
             hostname={{ target_host }} domain={{ domain }} \
             --- quiet
    initrd   /install.amd/initrd.gz
}

menuentry --hotkey=r "Rescue: drop to manual installer" {
    set background_color=black
    linux    /install.amd/vmlinuz vga=788 --- quiet
    initrd   /install.amd/initrd.gz
}
