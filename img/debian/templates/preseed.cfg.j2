# Debian 13 (Trixie) preseed for {{ target_host }}
# Rendered by img/debian/playbook.yml from ansible/inventory.yaml — do not edit by hand.
# Loaded by d-i from /cdrom/preseed.cfg (path baked into the boot configs).

### Localization
d-i debian-installer/locale string en_US.UTF-8
d-i keyboard-configuration/xkb-keymap select us

### Network — DHCP only. The host's static IP is owned by the OPNsense
### dnsmasq reservation tied to MAC(s) {{ host.mac_addresses | join(', ') }}.
d-i netcfg/choose_interface select auto
d-i netcfg/hostname string {{ target_host }}
d-i netcfg/get_hostname string {{ target_host }}
d-i netcfg/get_domain string {{ domain }}
d-i netcfg/wireless_wep string

### Mirror
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

### Accounts — the two guaranteed-access accounts (created in late_command
### below) are the install-time GUARANTEE that every freshly imaged Debian
### host has equal-shape ansible + break-glass access, independent of any
### later host-base run.
#
#   root         → LOCKED (no password set; the installer leaves root with
#                  `!`/`*` in /etc/shadow). Direct root login is blocked at
#                  every layer: console, SSH (`PermitRootLogin no` drop-in
#                  written in late_command, mirroring the ssh-hardening
#                  role's fleet policy), and password (account is locked).
#                  `sudo` from ansible/tourmanager is the only way to gain
#                  root, and a real human break-glass goes through
#                  tourmanager on the console.
#   ansible      → key-only automation account, NOPASSWD sudo. Same canonical
#                  pubkey the rest of the automation trusts.
#   tourmanager  → password-only break-glass account, NOPASSWD sudo. SSH
#                  password auth is denied globally by ssh-hardening but a
#                  `Match User tourmanager` block carves out password auth for
#                  this account specifically. Until ssh-hardening runs, sshd's
#                  default config also permits password auth for it. Console
#                  login always works.
d-i passwd/root-login boolean false
d-i passwd/make-user boolean false

### Clock
d-i clock-setup/utc boolean true
d-i time/zone string {{ timezone }}
d-i clock-setup/ntp boolean true

### Partitioning — whole-disk LVM on the inventory-marked boot disk.
# The host-disks role still owns the post-install `vms` / `longhorn-data`
# carve on any additional disks; this preseed only owns the boot disk.
#
# Install target resolution: the boot disk is pinned in inventory by
# `storage.disks[?select == 'boot'].hw.{model, serial}` (single source
# of truth — no parallel `debian_install.disk` field). The
# `partman/early_command` below walks lsblk at install time and writes
# the matching /dev path into the partman-auto/disk and
# grub-installer/bootdev debconf settings, identical to the bootserv
# netboot preseed. Hook choice matters: per the Debian preseed manual,
# `preseed/early_command` runs before partman's disk discovery (lsblk
# can return nothing), while `partman/early_command` is the documented
# hook for "dynamic partitioner preseeding that depends on the state
# of the disks".
{% set _boot_entry = (host.storage.disks | selectattr('select', 'eq', 'boot') | list | first) %}
{% set _hw = _boot_entry.hw %}

d-i partman/early_command string \
    set -e; \
    M='{{ _hw.model }}'; S='{{ _hw.serial }}'; \
    LOG=/tmp/install-resolver.log; \
    : > "$LOG"; exec >>"$LOG" 2>&1; \
    install_disk=""; \
    for d in /sys/block/*; do \
        bn=${d##*/}; \
        case "$bn" in loop*|ram*|sr*|fd*|dm-*|md*) continue;; esac; \
        [ -r "$d/device/model" ] || { echo "skip /dev/$bn (no model)"; continue; }; \
        m=$(tr -d ' \t\r\n' < "$d/device/model"); \
        s=""; \
        [ -r "$d/device/serial" ] && s=$(tr -d ' \t\r\n' < "$d/device/serial"); \
        echo "candidate: /dev/$bn model='$m' serial='$s'"; \
        if [ "$m" = "$M" ] && [ "$s" = "$S" ]; then install_disk="/dev/$bn"; break; fi; \
    done; \
    cat "$LOG" >/dev/tty4 2>/dev/null || true; \
    if [ -z "$install_disk" ]; then \
        { echo; echo "================================================================"; echo "  INSTALL HALTED on {{ target_host }}: no disk matches inventory hw pin"; echo "    expected model='$M' serial='$S'"; echo "  log: $LOG  (Alt+F2 for shell, Alt+F4 for syslog)"; echo "  Sleeping 1h."; echo "================================================================"; } | tee -a "$LOG" >/dev/tty4 2>/dev/null || true; \
        sleep 3600; exit 1; \
    fi; \
    echo "RESOLVED install_disk=$install_disk" | tee -a "$LOG" >/dev/tty4 2>/dev/null || true; \
    if [ -r /usr/share/debconf/confmodule ]; then \
        . /usr/share/debconf/confmodule; \
        db_set partman-auto/disk "$install_disk"; \
        db_set grub-installer/bootdev "$install_disk"; \
    else \
        debconf-set partman-auto/disk "$install_disk"; \
        debconf-set grub-installer/bootdev "$install_disk"; \
    fi

# The two debconf values below are placeholders — the early_command
# above rewrites them at install time. Still preseeded so that on
# silent early_command failure, partman refuses rather than auto-
# picking some disk.
d-i partman-auto/disk string /dev/__resolved_by_early_command__
d-i partman-auto/method string lvm
d-i partman-lvm/device_remove_lvm boolean true
d-i partman-md/device_remove_md boolean true
d-i partman-lvm/confirm boolean true
d-i partman-lvm/confirm_nooverwrite boolean true
d-i partman-auto/choose_recipe select atomic
d-i partman-auto-lvm/new_vg_name string system
d-i partman/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

### Apt
d-i apt-setup/non-free boolean false
d-i apt-setup/non-free-firmware boolean true
d-i apt-setup/contrib boolean false
d-i apt-setup/services-select multiselect security, updates

### Packages — minimal base + SSH. Everything else is Ansible's job.
tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string openssh-server python3 sudo curl ca-certificates gnupg
d-i pkgsel/upgrade select full-upgrade
d-i pkgsel/update-policy select none
popularity-contest popularity-contest/participate boolean false

### Bootloader
d-i grub-installer/only_debian boolean true
d-i grub-installer/with_other_os boolean true
d-i grub-installer/bootdev string /dev/__resolved_by_early_command__

### Finish
d-i finish-install/reboot_in_progress note

### Late command — create the two guaranteed-access accounts, deny root
### SSH, and mask unattended-upgrades (fleet policy: "patching is
### deliberate, not unattended"; see roles/apt-no-auto-upgrades).
###
###   ansible      → key-only automation account, NOPASSWD sudo.
###                  authorized_keys is shipped on the ISO at
###                  /cdrom/authorized_keys so we avoid shell-escaping
###                  a pubkey inside this single-line directive.
###   tourmanager  → password-only break-glass account, NOPASSWD sudo.
###                  The crypt(3) SHA-512 hash is computed by Ansible
###                  with a deterministic per-host salt so rebuilding
###                  the ISO is idempotent. Plaintext never reaches
###                  disk: `useradd -p` takes the hash directly, and
###                  the hash itself is shell-safe.
###
### Both are also created/reconciled later by host-base on every
### Ansible run; the preseed copies exist so a fresh netboot install
### has them BEFORE any play touches the box.
{% set _tm_salt = (target_host ~ '-tourmanager-salt-v1') | hash('sha256') %}
{% set _tm_salt = _tm_salt[:16] %}
{% set _tm_hash = tourmanager_user_pass | password_hash('sha512', _tm_salt) %}
d-i preseed/late_command string \
    in-target useradd -m -s /bin/bash -G sudo ansible ; \
    in-target install -d -o ansible -g ansible -m 0700 /home/ansible/.ssh ; \
    cp /cdrom/authorized_keys /target/home/ansible/.ssh/authorized_keys ; \
    in-target chown ansible:ansible /home/ansible/.ssh/authorized_keys ; \
    in-target chmod 0600 /home/ansible/.ssh/authorized_keys ; \
    in-target sh -c 'echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible' ; \
    in-target chmod 0440 /etc/sudoers.d/ansible ; \
    in-target useradd -m -s /bin/bash -G sudo -p '{{ _tm_hash }}' tourmanager ; \
    in-target sh -c 'echo "tourmanager ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/tourmanager' ; \
    in-target chmod 0440 /etc/sudoers.d/tourmanager ; \
    in-target sh -c 'echo "PermitRootLogin no" > /etc/ssh/sshd_config.d/00-no-root.conf' ; \
    in-target chmod 0644 /etc/ssh/sshd_config.d/00-no-root.conf ; \
    in-target sh -c 'echo "APT::Periodic::Update-Package-Lists \"0\";" > /etc/apt/apt.conf.d/99-no-auto-upgrades' ; \
    in-target sh -c 'echo "APT::Periodic::Unattended-Upgrade \"0\";" >> /etc/apt/apt.conf.d/99-no-auto-upgrades' ; \
    in-target systemctl mask apt-daily.timer apt-daily-upgrade.timer
